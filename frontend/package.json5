{
  // Frontend package name for the portfolio site
  "name": "frontend",
  // Version of this frontend package
  "version": "1.0.13",
  // Prevents accidental publishing to npm registry
  "private": true,
  // Use ECMAScript modules (ESM)
  "type": "module",
  // Frontend development and build scripts
  "scripts": {
    // Validate required environment variables before starting dev
    "predev": "tsx ./scripts/check-required-env.ts",
    // Start Next.js development server with hot reload (default port: 3000)
    "dev": "next dev --webpack -p ${PORT:-3000}",
    // Start dev server on port 3002 (handy when 3000 is occupied by Docker/proxy)
    "dev:3002": "PORT=3002 npm run dev",
    // Check required environment variables for current profile
    "prebuild": "tsx ./scripts/check-required-env.ts",
    // Build production-optimized static site
    "build": "next build --webpack",
    // 🧰 Explicit Webpack build target for comparing bundler output or debugging prod-only bugs.
    "build:webpack": "next build --webpack",
    // 🏗️ Build the "when-ready" component (pre-build step to prepare assets used to gate rendering until env is ready)
    "build:when-ready": "node ./scripts/pre-build.mjs",
    // Experimental build with Turbopack (faster bundling)
    "turbopack": "NEXT_TELEMETRY_DISABLED=1 next build --turbopack",
    // Preview the built static site using serve
    "preview": "npx serve out",
    // Validate required environment variables before starting production server
    "prestart": "tsx ./scripts/check-required-env.ts",
    // Start Next.js production server
    "start": "next start",
    // Build, stage standalone assets, and run the frontend in production-like mode.
    "start:prod-like": "sh ./scripts/start-prod-like.sh",
    // Same as start:prod-like, but preconfigures the backend URL for local Docker backend testing.
    "start:prod-like:local": "BACKEND_INTERNAL_URL=http://localhost:8081 sh ./scripts/start-prod-like.sh",
    // Same as start:prod-like, but leaves the process running in the background and writes a pid/log file.
    "start:prod-like:detached": "DETACH=1 sh ./scripts/start-prod-like.sh",
    // Same as start:prod-like:local, but detached for side-by-side testing with Docker local.
    "start:prod-like:local:detached": "BACKEND_INTERNAL_URL=http://localhost:8081 DETACH=1 sh ./scripts/start-prod-like.sh",
    // Restart the detached production-like frontend process without changing its port selection.
    "start:prod-like:detached:restart": "DETACH=1 RESTART=1 sh ./scripts/start-prod-like.sh",
    // Restart the detached production-like frontend with the local backend URL preconfigured.
    "start:prod-like:local:detached:restart": "BACKEND_INTERNAL_URL=http://localhost:8081 DETACH=1 RESTART=1 sh ./scripts/start-prod-like.sh",
    // Report whether the detached production-like frontend is running for the selected port.
    "start:prod-like:status": "sh ./scripts/status-prod-like.sh",
    // Rebuild and restart the production-like frontend when watched files change.
    "start:prod-like:watch": "tsx ./scripts/watch-prod-like.ts",
    // Export the current project-data snapshot consumed by the portfolio frontend.
    "snapshot:projects": "tsx ./scripts/export-project-data-snapshot.ts",
    // Produce a redacted version of the project-data snapshot for secret-safe sharing.
    "snapshot:projects:secret": "tsx ./scripts/prepare-project-data-snapshot-secret.ts",
    // Write the redacted project-data snapshot to a cache file for later reuse.
    "snapshot:projects:secret:file": "tsx ./scripts/prepare-project-data-snapshot-secret.ts > ./.cache/project-data-snapshot.secret.json",
    // Run Next.js ESLint configuration
    "lint": "eslint .",
    // "Pretty Build" - format code with Prettier then run TypeScript build for validation
    "precommit": "prettier --write \"src/**/*.{ts,tsx,js,jsx,scss,css,md}\" && tsc -b",
    // Come back to this when there's time to write some tests.
    "test": "vitest run",
  },
  // Runtime dependencies for the frontend application
  "dependencies": {
    // AWS SDK v3 S3 client (used for signed-URL uploads)
    "@aws-sdk/client-s3": "^3.1037.0",
    // AWS SDK v3 presigner for generating pre-signed S3 requests
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    // Modern Redux state management with simplified API
    "@reduxjs/toolkit": "^2.11.2",
    // AWS CloudWatch RUM for real user monitoring and visitor traffic tracking
    "aws-rum-web": "^2.1.0",
    // CSS framework for responsive design and components
    "bootstrap": "^5.3.8",
    // Utility for conditionally joining CSS class names
    "clsx": "^2.1.1",
    // Professional animation library for smooth UI transitions
    "gsap": "^3.15.0",
    // HTTP client for making API requests
    "jsonwebtoken": "^9.0.3",
    // Next.js framework (App Router + build pipeline)
    "next": "^16.2.4",
    // PixiJS renderer for interactive canvas experiences
    "pixi.js": "^8.18.1",
    // End-to-end browser automation used for UI and deployment smoke tests.
    "playwright": "^1.59.1",
    // React library for building user interfaces (v19 for latest features)
    "react": "^19.2.5",
    // React DOM renderer for web applications (matches React 19)
    "react-dom": "^19.2.5",
    // Official React bindings for Redux state management
    "react-redux": "^9.2.0",
    // Client-side routing utilities (used for interactive demo routes)
    "react-router-dom": "^7.14.2",
    // CSS preprocessor with variables, nesting, and mixins
    "sass": "^1.99.0",
  },
  // Development-only dependencies for tooling and type checking
  "devDependencies": {
    // ESLint configuration utilities (required by some plugins)
    "@eslint/eslintrc": "^3",
    // Browser testing utilities for rendering React components in unit/integration tests.
    "@testing-library/react": "^16.3.2",
    // TypeScript definitions for jsonwebtoken library
    "@types/jsonwebtoken": "^9.0.10",
    // Node.js TypeScript definitions (latest for Node 18+)
    "@types/node": "^25",
    // React TypeScript definitions (v19 for latest React features)
    "@types/react": "^19",
    // React DOM TypeScript definitions (v19 for latest React features)
    "@types/react-dom": "^19",
    // TypeScript-specific ESLint rules and best practices
    "@typescript-eslint/eslint-plugin": "8.58.1",
    // TypeScript parser for ESLint to understand TS syntax
    "@typescript-eslint/parser": "8.58.1",
    // Load environment variables during local builds and scripts
    "dotenv": "17.4.2",
    // JavaScript/TypeScript linting engine (v9 for latest rules)
    "eslint": "^9.39.4",
    // Next.js ESLint configuration with React and accessibility rules
    "eslint-config-next": "16.2.4",
    // ESLint plugin for React Hooks rules and best practices
    "eslint-plugin-react-hooks": "^7.1.1",
    // ESLint plugin for React Refresh (fast refresh) compatibility
    "eslint-plugin-react-refresh": "^0.5.2",
    // Browser-like DOM environment used by Vitest component and hook tests.
    "jsdom": "^29.0.2",
    // Opinionated code formatter for consistent style
    "prettier": "^3.8.3",
    // Lightweight TypeScript runtime for executing guard scripts
    "tsx": "^4.21.0",
    // TypeScript compiler (v5 for latest language features)
    "typescript": "6.0.3",
    // Fast unit and integration test runner for the frontend package.
    "vitest": "^4.1.5",
  },
  // Toolchain version constraints for local dev and CI
  "engines": {
    // Node.js runtime version range supported by this repo
    "node": ">=18.20.2 <26",
    // Pin npm 11 so lockfile writes stay consistent across local/dev/prod installs.
    "npm": ">=11 <12",
    // pnpm major versions supported (used by some scripts/workflows)
    "pnpm": "^9 || ^10",
  },
}