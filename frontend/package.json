{
  "name": "frontend",
  "version": "0.0.87",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "tsx ./scripts/check-required-env.ts",
    "dev": "next dev --webpack -p ${PORT:-3000}",
    "dev:3002": "PORT=3002 npm run dev",
    "prebuild": "tsx ./scripts/check-required-env.ts",
    "build": "next build --webpack",
    "build:webpack": "next build --webpack",
    "build:when-ready": "tsx ./scripts/pre-build.ts",
    "build:turbopack": "NEXT_TELEMETRY_DISABLED=1 next build --turbopack",
    "preview": "npx serve out",
    "prestart": "tsx ./scripts/check-required-env.ts",
    "start": "next start",
    "start:prod-like": "sh ./scripts/start-prod-like.sh",
    "start:prod-like:local": "BACKEND_INTERNAL_URL=http://localhost:8081 sh ./scripts/start-prod-like.sh",
    "start:prod-like:detached": "DETACH=1 sh ./scripts/start-prod-like.sh",
    "start:prod-like:local:detached": "BACKEND_INTERNAL_URL=http://localhost:8081 DETACH=1 sh ./scripts/start-prod-like.sh",
    "start:prod-like:detached:restart": "DETACH=1 RESTART=1 sh ./scripts/start-prod-like.sh",
    "start:prod-like:local:detached:restart": "BACKEND_INTERNAL_URL=http://localhost:8081 DETACH=1 RESTART=1 sh ./scripts/start-prod-like.sh",
    "start:prod-like:status": "sh ./scripts/status-prod-like.sh",
    "start:prod-like:watch": "tsx ./scripts/watch-prod-like.ts",
    "snapshot:projects": "tsx ./scripts/export-project-data-snapshot.ts",
    "snapshot:projects:secret": "tsx ./scripts/prepare-project-data-snapshot-secret.ts",
    "snapshot:projects:secret:write": "tsx ./scripts/prepare-project-data-snapshot-secret.ts > ./.cache/project-data-snapshot.secret.json",
    "snapshot:static-content": "tsx ./scripts/export-static-content-snapshot.ts",
    "snapshot:static-content:secret": "tsx ./scripts/prepare-static-content-snapshot-secret.ts",
    "snapshot:static-content:secret:write": "npm run snapshot:static-content && tsx ./scripts/prepare-static-content-snapshot-secret.ts > ./.cache/static-content-snapshot.secret.json",
    "social-image:generate": "tsx ./scripts/generate-social-image.ts",
    "lint": "eslint .",
    "precommit": "prettier --write \"src/**/*.{ts,tsx,js,jsx,scss,css,md}\" && tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "@reduxjs/toolkit": "^2.12.0",
    "aws-rum-web": "^3.1.0",
    "bootstrap": "^5.3.8",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.10",
    "pixi.js": "^8.19.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "dotenv": "17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^20.13.0 || ^22.13.0 || >=24 <26",
    "npm": ">=10.5 <12",
    "pnpm": "^9 || ^10"
  }
}
