{
  "name": "bb-portfolio-monorepo-root",
  "version": "0.0.86",
  "private": true,
  "engines": {
    "node": ">=18.20.2 <26",
    "npm": ">=11 <12",
    "pnpm": "^9 || ^10"
  },
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:tabs": "osascript -e 'tell application \"Terminal\" to do script \"cd \\\"$(pwd)/backend\\\" && npm run dev\"' && osascript -e 'tell application \"Terminal\" to do script \"cd \\\"$(pwd)/frontend\\\" && npm run dev\"'",
    "build:all": "npm run format && concurrently \"npm run build:backend\" \"npm run build:frontend\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:frontend:webpack": "cd frontend && npm run build:webpack",
    "build:frontend:turbopack": "cd frontend && npm run build:turbopack",
    "docker:build": "docker compose -f deploy/compose/docker-compose.yml --profile local build",
    "docker:build:backend": "bash deploy/scripts/docker-build-backend-dev-image.sh",
    "docker:build:frontend": "bash deploy/scripts/docker-build-frontend-dev-image.sh",
    "images:publish:dev": "bash deploy/scripts/publish-dockerhub-dev-images.sh",
    "docker:down": "docker compose -f deploy/compose/docker-compose.yml --profile local down",
    "docker:logs": "docker compose -f deploy/compose/docker-compose.yml --profile local logs -f",
    "docker:maintenance": "zsh deploy/scripts/docker-maintenance.sh",
    "docker:push:backend": "docker push bhbaysinger/bb-portfolio-backend:dev",
    "docker:push:frontend": "docker push bhbaysinger/bb-portfolio-frontend:dev",
    "docker:smoke:admin": "cd backend && ADMIN_SMOKE_URL=http://localhost:8081/admin/login/ tsx scripts/smoke-admin-login.ts",
    "docker:ssg:build": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg build",
    "docker:ssg:down": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg down",
    "docker:ssg:logs": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg logs -f",
    "docker:ssg:up": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build",
    "docker:ssg:up:detached": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build -d",
    "docker:ssg:up:no-strict": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build",
    "docker:ssg:up:no-strict:detached": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build -d",
    "docker:up": "docker compose -f deploy/compose/docker-compose.yml --profile local up --build",
    "docker:up:detached": "docker compose -f deploy/compose/docker-compose.yml --profile local up --build -d",
    "docker:up:no-strict": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local up --build",
    "docker:up:no-strict:detached": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local up --build -d",
    "caddy:config:apply": "npm run caddy:config:validate && npm run caddy:config:reload",
    "caddy:config:reload": "COMPOSE_PROFILES=local,proxy docker compose -f deploy/compose/docker-compose.yml exec -T caddy-local caddy reload --config /etc/caddy/Caddyfile --adapter caddyfile",
    "caddy:config:validate": "COMPOSE_PROFILES=local,proxy docker compose -f deploy/compose/docker-compose.yml exec -T caddy-local caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile",
    "caddy:down": "zsh deploy/scripts/caddy-helper.sh down",
    "caddy:down:force": "docker rm -f bb-portfolio-backend-local bb-portfolio-frontend-local bb-portfolio-caddy-local || true",
    "caddy:logs": "zsh deploy/scripts/caddy-helper.sh logs",
    "caddy:reload": "docker exec bb-portfolio-caddy-local caddy reload --config /etc/caddy/Caddyfile",
    "caddy:status": "docker ps --filter name=bb-portfolio- --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}'",
    "caddy:restart": "zsh deploy/scripts/caddy-helper.sh restart",
    "caddy:up": "zsh deploy/scripts/caddy-helper.sh up",
    "caddy:up:no-strict": "REACT_STRICT_MODE=false zsh deploy/scripts/caddy-helper.sh up",
    "frontend:prod-like:up": "cd frontend && PORT=${PORT:-3004} npm run start:prod-like:local:detached",
    "frontend:prod-like:down": "cd frontend && PORT=${PORT:-3004} sh ./scripts/stop-prod-like.sh",
    "frontend:prod-like:watch": "cd frontend && PORT=${PORT:-3004} BACKEND_INTERNAL_URL=${BACKEND_INTERNAL_URL:-http://localhost:8081} npm run start:prod-like:watch",
    "frontend:prod-like:restart": "cd frontend && PORT=${PORT:-3004} npm run start:prod-like:local:detached:restart",
    "frontend:prod-like:status": "cd frontend && PORT=${PORT:-3004} sh ./scripts/status-prod-like.sh",
    "frontend:prod-like:logs": "cd frontend && tail -f ./.runtime/prod-like/logs/prod-like-${PORT:-3004}.log",
    "frontend:purge": "docker exec -t bb-portfolio-frontend-local sh -lc 'rm -rf .next && echo Purged .next'",
    "frontend:rebuild:ssg": "npm run docker:ssg:build",
    "frontend:restart": "docker restart bb-portfolio-frontend-local",
    "format": "prettier --write . && npm run format:shell",
    "format:shell": "bash scripts/format-shell.sh --write",
    "lint": "eslint .",
    "test": "npm --prefix frontend test",
    "precommit": "prettier --write . && eslint . --fix && tsc --noEmit && npm run sync:json5 && npm run format:shell",
    "prepush": "npm run precommit && npm test",
    "audit:fix:all": "concurrently \"npm audit fix\" \"cd backend && npm audit fix\" \"cd frontend && npm audit fix\" --names \"root,backend,frontend\" --prefix-colors \"yellow,blue,green\"",
    "secrets:bundle": "tsx scripts/merge-github-secrets.ts",
    "secrets:update-from-terraform": "tsx scripts/update-github-secrets-from-terraform.ts",
    "version:bump:sync": "tsx scripts/bump-sync-version.ts",
    "sync:json5": "json5-manifest-sync --blank-comments=fill",
    "snapshot:projects": "npm --prefix frontend run snapshot:projects",
    "snapshot:projects:secret": "npm --prefix frontend run snapshot:projects:secret",
    "snapshot:projects:secret:write": "npm --prefix frontend run snapshot:projects:secret:write",
    "snapshot:projects:secret:refresh": "npm --prefix frontend run snapshot:projects && npm --prefix frontend run snapshot:projects:secret:write",
    "snapshot:static-content": "npm --prefix frontend run snapshot:static-content",
    "snapshot:static-content:secret": "npm --prefix frontend run snapshot:static-content:secret",
    "snapshot:static-content:secret:write": "npm --prefix frontend run snapshot:static-content:secret:write",
    "snapshot:static-content:secret:refresh": "npm --prefix frontend run snapshot:static-content:secret:write",
    "social-image:generate": "npm --prefix frontend run social-image:generate",
    "sync:secrets": "tsx scripts/sync-github-secrets.ts BBaysinger/bb-portfolio ./.github-secrets.private.json5",
    "sync:secrets:dry": "tsx scripts/sync-github-secrets.ts BBaysinger/bb-portfolio ./.github-secrets.private.json5 --dry-run",
    "install:all": "concurrently \"npm install\" \"cd backend && npm install\" \"cd frontend && npm install\" --names \"root,backend,frontend\" --prefix-colors \"yellow,blue,green\"",
    "update:deps": "tsx scripts/update-deps-guarded.ts",
    "update:deps:dry": "tsx scripts/update-deps-guarded.ts --dry-run",
    "update:deps:raw": "concurrently \"ncu -u\" \"cd backend && ncu -u\" \"cd frontend && ncu -u\" --names \"root,backend,frontend\" --prefix-colors \"yellow,blue,green\"",
    "content:migrate": "bash ./scripts/content-workflow.sh migrate",
    "content:migrate:local-to-dev:refresh-snapshots": "bash ./scripts/migrate-and-refresh-snapshots.sh --source local --target dev",
    "content:migrate:local-to-prod:refresh-snapshots": "bash ./scripts/migrate-and-refresh-snapshots.sh --source local --target prod",
    "content:pull:local:content-dir": "bash ./scripts/content-workflow.sh pull-local",
    "content:pull:dev:content-dir": "bash ./scripts/content-workflow.sh pull-dev",
    "content:pull:local:all": "bash ./scripts/content-workflow.sh pull-local-all",
    "content:pull:dev:all": "bash ./scripts/content-workflow.sh pull-dev-all",
    "content:import:local:content-dir": "bash ./scripts/content-workflow.sh import-local",
    "content:import:local:projects:content-dir": "bash ./scripts/content-workflow.sh import-projects-local",
    "content:import:local:cv:content-dir": "bash ./scripts/content-workflow.sh import-cv-local",
    "content:import:dev:content-dir": "bash ./scripts/content-workflow.sh import-dev",
    "content:import:prod:content-dir": "bash ./scripts/content-workflow.sh import-prod",
    "data:sync": "bash ./scripts/migrate-database.sh",
    "content:pull:prod:content-dir": "bash ./scripts/content-workflow.sh pull-prod",
    "content:pull:prod:content-dir:dry": "bash ./scripts/content-workflow.sh pull-prod-dry",
    "content:pull:prod:all": "bash ./scripts/content-workflow.sh pull-prod-all",
    "content:pull:prod:all:dry": "bash ./scripts/content-workflow.sh pull-prod-all-dry",
    "media:export": "bash scripts/export-media.sh",
    "media:pull": "tsx scripts/pull-media-from-s3.ts",
    "media:pull:prod:cv-experience-logos": "tsx scripts/pull-media-from-s3.ts --env prod --collection cv-experience-logos",
    "media:pull:prod:cv-experience-logos:dry": "tsx scripts/pull-media-from-s3.ts --env prod --collection cv-experience-logos --dry-run",
    "media:pull:prod:project-brand-logos": "tsx scripts/pull-media-from-s3.ts --env prod --collection project-brand-logos",
    "media:pull:prod:project-brand-logos:dry": "tsx scripts/pull-media-from-s3.ts --env prod --collection project-brand-logos --dry-run",
    "media:import": "tsx scripts/import-media-from-snapshot-root.ts",
    "media:upload": "tsx scripts/upload-media-to-s3.ts",
    "media:upload:dev": "tsx scripts/upload-media-to-s3.ts --env dev",
    "media:upload:dev:dry": "tsx scripts/upload-media-to-s3.ts --env dev --dry-run",
    "media:upload:prod": "tsx scripts/upload-media-to-s3.ts --env prod",
    "media:upload:prod:dry": "tsx scripts/upload-media-to-s3.ts --env prod --dry-run",
    "media:upload:both": "tsx scripts/upload-media-to-s3.ts --env both",
    "media:upload:both:dry": "tsx scripts/upload-media-to-s3.ts --env both --dry-run",
    "media:guards:smoke": "bash scripts/test-media-freshness-guards.sh",
    "media:verify": "tsx scripts/verify-media-s3.ts",
    "migrate:media-urls:dev:dry": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env dev --dry-run",
    "migrate:media-urls:dev": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env dev",
    "migrate:media-urls:prod:dry": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env prod --dry-run",
    "migrate:media-urls:prod": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env prod",
    "migrate:all:dev:dry": "npm run media:upload:dev:dry && npm run migrate:media-urls:dev:dry",
    "migrate:all:dev": "npm run media:upload:dev && npm run migrate:media-urls:dev",
    "migrate:all:prod:dry": "npm run media:upload:prod:dry && npm run migrate:media-urls:prod:dry",
    "migrate:all:prod": "npm run media:upload:prod && npm run migrate:media-urls:prod",
    "projects:upload": "tsx scripts/upload-projects-to-s3.ts",
    "projects:upload:public": "tsx scripts/upload-projects-to-s3.ts --env public",
    "projects:upload:nda": "tsx scripts/upload-projects-to-s3.ts --env nda",
    "projects:upload:both": "tsx scripts/upload-projects-to-s3.ts --env both",
    "projects:verify": "tsx scripts/verify-projects-s3.ts",
    "db:migrate:local-to-dev": "bash scripts/migrate-database.sh local dev",
    "db:migrate:prod-to-dev": "bash scripts/migrate-database.sh prod dev",
    "db:migrate:prod-to-local": "bash scripts/migrate-database.sh prod local",
    "db:migrate:prod-to-all": "npm run db:migrate:prod-to-dev && npm run db:migrate:prod-to-local",
    "db:restore:auth:prod": "bash scripts/restore-collections-from-backup.sh prod",
    "db:restore:auth:prod:dry": "bash scripts/restore-collections-from-backup.sh prod --dry-run",
    "db:restore:auth:dev": "bash scripts/restore-collections-from-backup.sh dev",
    "db:restore:auth:dev:dry": "bash scripts/restore-collections-from-backup.sh dev --dry-run",
    "deploy": "bash deploy/scripts/deployment-runner.sh --profiles both --refresh-env",
    "deploy:rebuild": "bash deploy/scripts/deployment-runner.sh --profiles both --rebuild-images --refresh-env",
    "deploy:no-build": "bash deploy/scripts/deployment-runner.sh --profiles both --no-build --refresh-env",
    "deploy:skip-infra": "bash deploy/scripts/deployment-runner.sh --profiles both --skip-infra --refresh-env",
    "ecr:build:push": "bash deploy/scripts/publish-ecr-images.sh",
    "infra:sync-env": "cd infra && bash sync-env-from-terraform.sh",
    "infra:sync-env:force": "cd infra && bash sync-env-from-terraform.sh --force",
    "images:cleanup": "bash ./scripts/image-cleanup.sh --retain 3 --include-untagged --login --profile bb-portfolio-user --region us-west-2",
    "images:cleanup:dry-run": "bash ./scripts/image-cleanup.sh --retain 3 --include-untagged --login --profile bb-portfolio-user --region us-west-2 --dry-run",
    "images:cleanup:ecr": "bash ./scripts/image-cleanup-ecr.sh --retain 3 --include-untagged",
    "images:cleanup:ecr:dry-run": "bash ./scripts/image-cleanup-ecr.sh --retain 3 --include-untagged --dry-run",
    "images:cleanup:login": "bash ./scripts/image-cleanup.sh --retain 3 --include-untagged --login --profile bb-portfolio-user --region us-west-2",
    "images:verify": "bash ./scripts/images-verify.sh",
    "images:verify:login": "bash ./scripts/images-verify.sh --login --profile bb-portfolio-user --region us-west-2",
    "search:repo": "rg --line-number --hidden --follow --glob '!.git' --glob '!node_modules' --glob '!frontend/.next' --glob '!backend/.next'",
    "search:files": "rg --files --hidden --follow --glob '!.git' --glob '!node_modules' --glob '!frontend/.next' --glob '!backend/.next'",
    "release:promote": "bash ./scripts/sync-branches.sh",
    "release:sync-only": "bash ./scripts/sync-branches.sh --no-version-bump"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/glob": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "baseline-browser-mapping": "^2.10.40",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "ignore": "^7.0.5",
    "jiti": "^2.7.0",
    "json5": "^2.2.3",
    "json5-manifest-sync": "^0.2.2",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3"
  }
}
