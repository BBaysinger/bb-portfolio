# ─────────────────────────────────────────────
# 📦 Node.js & Build Artifacts
# ─────────────────────────────────────────────
**/node_modules/
**/dist/
**/dist-ssr/
**/.next/
/frontend/out/
frontend/.cache/**
*.local

# ─────────────────────────────────────────────
# 📦 NPM Cache (created in containers)
# ─────────────────────────────────────────────
**/.npm/
**/.npm-cache/
# Explicit service-level caches (backend & frontend) in case patterns above miss
backend/.npm-cache/**
frontend/.npm-cache/**
# Safety: ignore yarn/pnpm cache directories if ever added
**/.yarn-cache/
**/.pnpm-store/

# ─────────────────────────────────────────────
# 🧾 Logs
# ─────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────
# 🛠 Editor & Workspace Configs
# ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─────────────────────────────────────────────
# 🌐 Environment Files
# ─────────────────────────────────────────────
.env
.env.production
.env*
!**/.env*.example

# ─────────────────────────────────────────────
# 🌍 Hosting & Platform Folders
# ─────────────────────────────────────────────
.netlify/
.vercel/

# ─────────────────────────────────────────────
# ⚡️ Turborepo Cache
# ─────────────────────────────────────────────
.turbo/

# ─────────────────────────────────────────────
# 🧾 TypeScript Artifacts
# ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────
# 🧪 Testing & Coverage
# ─────────────────────────────────────────────
coverage/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# ─────────────────────────────────────────────
# 📁 Backend Uploads (keep dirs, ignore contents)
# Seeded locally, uploaded (S3/Payload) in deploys
# ─────────────────────────────────────────────
# New convention: backend/media/*
backend/media/**
!backend/media/**/.gitkeep

# ─────────────────────────────────────────────
# Terraform
# ─────────────────────────────────────────────

# Terraform state
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan
**/*.tfplan
infra/tfplan

# Local overrides
terraform.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# CLI config
.terraformrc
terraform.rc

# ===============================================================
# Github secrets & Database backups
# ===============================================================

# Combined secrets bundle (generated from per-environment files)
.github-secrets.private.json5
# Environment-scoped secrets
.github-secrets.private.*.json5

# ─────────────────────────────────────────────
# 🗄️ Database Backups & Migration Files
# ─────────────────────────────────────────────
# Ignore backup artifacts under data/ but keep curated seed dumps tracked
data/database-backups/**
!data/database-backups/.gitkeep
# Backup folder at repo root (ignored)
/database-backups/**
temp_dump_*
*.bson
*.metadata.json

# ─────────────────────────────────────────────
# 🗃 Local Data Dumps (never commit)
# ─────────────────────────────────────────────
# Ignore ad-hoc or exported JSON dumps used for local testing only
data/dump/**
!data/dump/.gitkeep

# ─────────────────────────────────────────────
# 🔒 Internal security reports (untracked)
# ─────────────────────────────────────────────
security-findings-*.md
