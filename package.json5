{
  // =====================
  // Root package.json5 for monorepo tooling only
  // =====================
  // 📌 NOTE: This root package.json is ONLY for managing monorepo-level tooling and scripts.
  // It does not represent a real app or library (and should not be published to npm).
  // Root package name for the portfolio monorepo
  // Monorepo root name (not a real app or package)
  "name": "bb-portfolio-monorepo-root",
  // Canonical repo version; child packages are kept in sync from this value.
  "version": "1.0.65",
  // Prevents accidental publishing to npm registry
  // Prevent publishing to npm registry
  "private": true,
  // Toolchain version constraints for dev machines/CI
  "engines": {
    // Node.js runtime version range supported by this repo
    "node": ">=18.20.2 <26",
    // Pin npm 11 so lockfile writes stay consistent across local/dev/prod installs.
    "npm": ">=11 <12",
    // pnpm major versions supported (used by some scripts/workflows)
    "pnpm": "^9 || ^10",
  },
  // Optional: Enable npm workspaces by uncommenting the line below
  // "workspaces": ["frontend", "backend"],
  "scripts": {
    // Primary root dev entrypoint for running backend and frontend together.
    "dev": "npm run dev:all",
    // Run both local app servers concurrently with labeled output.
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    // Start only the backend app in local dev mode.
    "dev:backend": "cd backend && npm run dev",
    // Start only the frontend app in local dev mode.
    "dev:frontend": "cd frontend && npm run dev",
    // Open backend and frontend dev servers in separate Terminal.app tabs.
    "dev:tabs": "osascript -e 'tell application \"Terminal\" to do script \"cd \\\"$(pwd)/backend\\\" && npm run dev\"' && osascript -e 'tell application \"Terminal\" to do script \"cd \\\"$(pwd)/frontend\\\" && npm run dev\"'",
    // =============================================================================
    // 🚀 DEVELOPMENT MODES OVERVIEW (for junior developers)
    // =============================================================================
    // 1. 🖥️  Bare Metal: Run directly on your machine (fastest, most direct)
    // 2. 🐳 Docker SSR: Containerized with hot reload (pages render on-demand)
    // 3. 🏗️  Docker SSG: Pre-builds pages like production (slower, but tests real build)
    // 4. 🌐 Caddy Proxy: Same as SSR but with production-like URLs (single port)
    // 👇 Pick the workflow that matches the validation you need so you don't mix modes.
    // Choose based on what you're testing:
    // - Daily dev: Use Bare Metal or Docker SSR
    // - Pre-commit: Use Docker SSG to test production builds
    // - URL testing: Use Caddy for production-like routing
    // =============================================================================
    // 🖥️ Build both backend and frontend locally without Docker (bare metal, laptop dev)
    "build:all": "npm run format && concurrently \"npm run build:backend\" \"npm run build:frontend\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    // 🖥️ Build backend service locally (bare metal, laptop dev)
    "build:backend": "cd backend && npm run build",
    // 🖥️ Build frontend service locally (bare metal, laptop dev)
    "build:frontend": "cd frontend && npm run build",
    // 🧰 Force a plain Webpack build to reproduce issues that only happen outside Turbopack.
    "build:frontend:webpack": "cd frontend && npm run build:webpack",
    // 🚀 Experimental Turbopack build path for the frontend package.
    "build:frontend:turbopack": "cd frontend && npm run build:turbopack",
    // =============================================================================
    // 🐳 DOCKER DEVELOPMENT (Containerized - consistent across machines)
    // =============================================================================
    // 🐳 Build both frontend and backend Docker images using docker-compose local profile
    // Uses the local profile which includes development-optimized builds with hot reload
    "docker:build": "docker compose -f deploy/compose/docker-compose.yml --profile local build",
    // 🐳 Build backend Docker image for Docker Hub (dev tag)
    // NOTE: Builds the production runtime stage with ENV_PROFILE=dev (no hot reload)
    // This ensures EC2 dev behaves like prod, just with dev config.
    "docker:build:backend": "bash deploy/scripts/docker-build-backend-dev-image.sh",
    // 🐳 Build frontend Docker image for Docker Hub (dev tag)
    // NOTE: Builds the production runner stage with ENV_PROFILE=dev (no hot reload)
    // Dev internal URL points to the dev compose service name for server-to-server calls.
    "docker:build:frontend": "bash deploy/scripts/docker-build-frontend-dev-image.sh",
    // Build and publish both dev Docker images to Docker Hub in one guarded flow.
    "images:publish:dev": "bash deploy/scripts/publish-dockerhub-dev-images.sh",
    // 🛑 Stop and remove all local development containers
    // Cleans up containers, networks, and anonymous volumes created by docker:up
    "docker:down": "docker compose -f deploy/compose/docker-compose.yml --profile local down",
    // 📋 Follow logs from both frontend and backend containers in real-time
    // Useful when running in detached mode to see what's happening
    "docker:logs": "docker compose -f deploy/compose/docker-compose.yml --profile local logs -f",
    // 🧽 Run Docker cleanup + prune tasks to prevent stale containers, volumes, and caches. This is key if your machine runs out of disk space due to Docker images.
    "docker:maintenance": "zsh deploy/scripts/docker-maintenance.sh",
    // 🚀 Push backend Docker image to Docker Hub (dev tag)
    "docker:push:backend": "docker push bhbaysinger/bb-portfolio-backend:dev",
    // 🚀 Push frontend Docker image to Docker Hub (dev tag)
    "docker:push:frontend": "docker push bhbaysinger/bb-portfolio-frontend:dev",
    // 🩺 Quick smoke test: verify the local backend admin login route responds
    "docker:smoke:admin": "cd backend && ADMIN_SMOKE_URL=http://localhost:8081/admin/login/ node scripts/smoke-admin-login.mjs",
    // 🏗️ BUILD MODE: Build static site generation containers (local-ssg profile)
    "docker:ssg:build": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg build",
    // 🛑 Stop and remove static site generation containers (local-ssg profile)
    "docker:ssg:down": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg down",
    // 📋 Follow logs from static site generation containers in real-time (local-ssg profile)
    "docker:ssg:logs": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg logs -f",
    // 🏗️ PRODUCTION MODE (SSG): Pre-builds all pages with data baked-in at build time
    // Frontend: Static HTML files generated, Backend: Hot reload for development
    // Slower startup but faster page loads - tests how production will behave
    "docker:ssg:up": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build",
    // 🏗️ Same as docker:ssg:up but runs in background (detached mode)
    "docker:ssg:up:detached": "docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build -d",
    // 🏗️ Same as docker:ssg:up but with React Strict Mode disabled
    "docker:ssg:up:no-strict": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build",
    // 🏗️ Same as docker:ssg:up:no-strict but runs in background (detached mode)
    "docker:ssg:up:no-strict:detached": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local-ssg up --build -d",
    // ⚡ DEVELOPMENT MODE (SSR): Start containers with hot reload for fast development
    // Frontend: http://localhost:8080, Backend: http://localhost:8081
    // Uses 'npm run dev' with volume mounts - pages render on-demand with fresh data from backend
    "docker:up": "docker compose -f deploy/compose/docker-compose.yml --profile local up --build",
    // ▶️ Same as docker:up but runs in background (doesn't block your terminal)
    // Use this if you want to continue using your terminal while containers run
    "docker:up:detached": "docker compose -f deploy/compose/docker-compose.yml --profile local up --build -d",
    // ⚡ Same as docker:up but with React Strict Mode disabled
    // Useful when React's strict mode causes issues with third-party components
    "docker:up:no-strict": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local up --build",
    // ▶️ Same as docker:up:no-strict but runs in background (detached mode)
    "docker:up:no-strict:detached": "REACT_STRICT_MODE=false docker compose -f deploy/compose/docker-compose.yml --profile local up --build -d",
    // 🔁 One-shot: validate then reload Caddy if validation succeeds.
    "caddy:config:apply": "npm run caddy:config:validate && npm run caddy:config:reload",
    // 🚀 Apply the validated configuration with zero downtime via admin API.
    // Again, this only affects proxy config. It won’t refresh JS bundles.
    "caddy:config:reload": "COMPOSE_PROFILES=local,proxy docker compose -f deploy/compose/docker-compose.yml exec -T caddy-local caddy reload --config /etc/caddy/Caddyfile --adapter caddyfile",
    // ✅ Check only: validate Caddyfile syntax inside the running container (no changes applied).
    // Safe to run before reload. Use when editing the Caddyfile and you want to verify it parses.
    "caddy:config:validate": "COMPOSE_PROFILES=local,proxy docker compose -f deploy/compose/docker-compose.yml exec -T caddy-local caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile",
    // 🛑 Stop Caddy (and its dependencies) cleanly
    // Stop only Caddy via helper (no full reset)
    "caddy:down": "zsh deploy/scripts/caddy-helper.sh down",
    // 🧹 Force-remove a stale caddy container if it was created outside the current compose project
    "caddy:down:force": "docker rm -f bb-portfolio-backend-local bb-portfolio-frontend-local bb-portfolio-caddy-local || true",
    // 📋 Follow Caddy reverse proxy logs in real-time
    // Tail Caddy logs via helper
    "caddy:logs": "zsh deploy/scripts/caddy-helper.sh logs",
    // ⚡ Reload Caddy configuration without restarting containers.
    // Use this when you changed only the Caddyfile (routes/headers/upstreams). It does NOT rebuild frontend JS.
    // For fresh JS or assets, rebuild/recreate the frontend container (e.g., `docker:up` or `caddy:up`) so Next.js serves the new build.
    "caddy:reload": "docker exec bb-portfolio-caddy-local caddy reload --config /etc/caddy/Caddyfile",
    // 📊 Check status of portfolio containers
    "caddy:status": "docker ps --filter name=bb-portfolio- --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}'",
    // 🔄 Restart Caddy in-place (recreate only the proxy)
    // Restart Caddy via helper
    "caddy:restart": "zsh deploy/scripts/caddy-helper.sh restart",
    // 🌐 PROXY MODE (SSR + URL consistency): Single port access like production
    // Access everything at http://localhost:8080 — this mirrors prod’s “no explicit backend port in the URL” behavior.
    // When you run with the proxy (npm run caddy:up), you get a single entrypoint at http://localhost:8080 and:
    //   • /api and /admin are proxied to the backend
    //   • everything else goes to the frontend
    // The only “extra” is the Docker network (infrastructure), not an extra app.
    // Uses compose profiles: local (frontend+backend dev) + proxy (Caddy)
    // Hey AI: Use this command to start local development (this is the default)
    // Starts proxy + frontend using helper (warns if prune is overdue)
    "caddy:up": "zsh deploy/scripts/caddy-helper.sh up",
    // 🌐 Same as caddy:up but with React Strict Mode disabled
    // Same as caddy:up with React Strict Mode disabled
    "caddy:up:no-strict": "REACT_STRICT_MODE=false zsh deploy/scripts/caddy-helper.sh up",
    // Start the frontend in detached production-like mode on port 3004 by default so Docker local can stay up.
    "frontend:prod-like:up": "cd frontend && PORT=${PORT:-3004} npm run start:prod-like:local:detached",
    // Stop the detached production-like frontend instance for the selected port.
    "frontend:prod-like:down": "cd frontend && PORT=${PORT:-3004} sh ./scripts/stop-prod-like.sh",
    // Watch and rebuild the detached production-like frontend against a local backend.
    "frontend:prod-like:watch": "cd frontend && PORT=${PORT:-3004} BACKEND_INTERNAL_URL=${BACKEND_INTERNAL_URL:-http://localhost:8081} npm run start:prod-like:watch",
    // Restart the detached production-like frontend process for the selected port.
    "frontend:prod-like:restart": "cd frontend && PORT=${PORT:-3004} npm run start:prod-like:local:detached:restart",
    // Show whether the detached production-like frontend is running and where its logs live.
    "frontend:prod-like:status": "cd frontend && PORT=${PORT:-3004} sh ./scripts/status-prod-like.sh",
    // Tail logs from the detached production-like frontend instance.
    "frontend:prod-like:logs": "cd frontend && tail -f ./.runtime/prod-like/logs/prod-like-${PORT:-3004}.log",
    // Purge .next inside the running frontend dev container (forces clean rebuild on next request)
    "frontend:purge": "docker exec -t bb-portfolio-frontend-local sh -lc 'rm -rf .next && echo Purged .next'",
    // Rebuild images for the SSG profile (frontend gets a fresh production-style build)
    // Note: This rebuilds the profile’s images; to start them, run `docker:ssg:up` or `docker:ssg:up:detached`.
    "frontend:rebuild:ssg": "npm run docker:ssg:build",
    // ℹ️ To ensure JS is fresh:
    //   - In dev SSR mode, the frontend dev server handles HMR; use `docker:up` or `caddy:up` to start it. No Caddy reload needed for code changes.
    //   - For production-like builds, rebuild the frontend image (e.g., `docker:build:frontend`) and recreate the container via `caddy:restart` or `caddy:up`.
    // 🔧 Frontend container helpers (local dev):
    // Restart only the frontend dev container (use if HMR looks stuck)
    "frontend:restart": "docker restart bb-portfolio-frontend-local",
    // 💅 Format all files with Prettier
    // Ensures consistent code style across the entire monorepo
    "format": "prettier --write . && npm run format:shell",
    // 🐚 Format supported shell scripts with shfmt via the repo wrapper
    "format:shell": "bash scripts/format-shell.sh --write",
    // 🧼 Run ESLint on the full codebase
    // Great for catching JS/TS issues or team rule violations
    "lint": "eslint .",
    // 🧪 Run the frontend test suite from the monorepo root.
    "test": "npm --prefix frontend test",
    // ✅ Fast pre-commit validation (format + lint + type check + package sync)
    // Run before every commit for quick validation (~5-10 seconds)
    // Attempts to auto-fix fixable ESLint issues, then syncs package.json5 annotations back from package.json
    "precommit": "prettier --write . && eslint . --fix && tsc --noEmit && npm run sync:json5 && npm run format:shell",
    // 🛡️ Comprehensive pre-push validation (precommit + tests)
    // Run before pushing to ensure everything works (1-5 minutes)
    // Includes all precommit checks plus full test suite
    "prepush": "npm run precommit && npm test",
    // 🔒 Runs `npm audit fix` across root, backend, and frontend
    // Kept separate from update:deps because audit remediation can rewrite lockfiles/transitives outside the guarded ncu flow.
    // Use intentionally and review the resulting package-lock.json changes separately from routine dependency refreshes.
    "audit:fix:all": "concurrently \"npm audit fix\" \"cd backend && npm audit fix\" \"cd frontend && npm audit fix\" --names \"root,backend,frontend\" --prefix-colors \"yellow,blue,green\"",
    // 🧩 Optional: Merge env-specific secret fragments into a single JSON5.
    // Not required for sync:secrets — the sync script reads per-env manifests directly.
    "secrets:bundle": "tsx scripts/merge-github-secrets.ts",
    // 🔐 Populate local GitHub secrets JSON5 files from Terraform outputs + AWS profile creds.
    "secrets:update-from-terraform": "tsx scripts/update-github-secrets-from-terraform.ts",
    // 🔢 Increment the canonical root patch version and copy it to backend/frontend package manifests.
    "version:bump:sync": "tsx scripts/bump-sync-version.ts",
    // Backward-compatible alias for the JSON5 sync entrypoint used by existing docs and hooks.
    "sync:json5": "json5-manifest-sync --blank-comments=fill",
    // Export the current frontend project-data snapshot used for regression comparisons.
    "snapshot:projects": "npm --prefix frontend run snapshot:projects",
    // Prepare the redacted project snapshot payload for secret storage or sharing.
    "snapshot:projects:secret": "npm --prefix frontend run snapshot:projects:secret",
    // Write the redacted project snapshot to the frontend cache directory.
    "snapshot:projects:secret:write": "npm --prefix frontend run snapshot:projects:secret:write",
    // Refresh both the raw snapshot and the cached secret snapshot file in one run.
    "snapshot:projects:secret:refresh": "npm --prefix frontend run snapshot:projects && npm --prefix frontend run snapshot:projects:secret:write",
    // Export the current static-content snapshot used for build-time CMS-derived content inputs.
    "snapshot:static-content": "npm --prefix frontend run snapshot:static-content",
    // Prepare the redacted static-content snapshot payload for secret storage or sharing.
    "snapshot:static-content:secret": "npm --prefix frontend run snapshot:static-content:secret",
    // Write the redacted static-content snapshot to the frontend cache directory.
    "snapshot:static-content:secret:write": "npm --prefix frontend run snapshot:static-content:secret:write",
    // Refresh the cached secret static-content snapshot file from the latest source snapshot.
    "snapshot:static-content:secret:refresh": "npm --prefix frontend run snapshot:static-content:secret:write",
    // Generate the branded social image asset used by the frontend.
    "social-image:generate": "npm --prefix frontend run social-image:generate",
    // 📦 Sync GitHub secrets (repo + environments) from local JSON5 files.
    "sync:secrets": "tsx scripts/sync-github-secrets.ts BBaysinger/bb-portfolio ./.github-secrets.private.json5",
    // 🧪 Same as above but performs only a dry run.
    "sync:secrets:dry": "tsx scripts/sync-github-secrets.ts BBaysinger/bb-portfolio ./.github-secrets.private.json5 --dry-run",
    // 🔽 Install dependencies in all packages after updating
    // Run after update:deps to install the newly updated dependencies
    // Handles root, backend, and frontend package installations simultaneously
    "install:all": "concurrently \"npm install\" \"cd backend && npm install\" \"cd frontend && npm install\" --names \"root,backend,frontend\" --prefix-colors \"yellow,blue,green\"",
    // 📦 Guarded dependency update across root, backend, and frontend
    // Blocks known-bad major bumps (for example eslint@10 while current plugins only support eslint^9)
    // Keeps routine upgrades separate from npm audit fix so security-driven lockfile/transitive churn is reviewed independently.
    // Runs npm install per package root and syncs package.json5 only if everything succeeds
    "update:deps": "tsx scripts/update-deps-guarded.ts",
    // 🔎 Preview guarded updates without changing files
    // Shows which upgrades would be applied and which ones are blocked by guardrails
    "update:deps:dry": "tsx scripts/update-deps-guarded.ts --dry-run",
    // ⚠️ Raw npm-check-updates pass with no guardrails
    // Use only when you intentionally want unrestricted major version bumps
    "update:deps:raw": "concurrently \"ncu -u\" \"cd backend && ncu -u\" \"cd frontend && ncu -u\" --names \"root,backend,frontend\" --prefix-colors \"yellow,blue,green\"",
    // 🪄 Canonical aggregate dataset migration entrypoint. Uses an internal temporary staging dir rather than the configured content root.
    "content:migrate": "bash ./scripts/content-workflow.sh migrate",
    // 🪄 Migrate the full local dataset into dev, then refresh both frontend snapshot secrets from the dev environment and sync only dev/repo GitHub secrets.
    "content:migrate:local-to-dev:refresh-snapshots": "bash ./scripts/migrate-and-refresh-snapshots.sh --source local --target dev",
    // 🪄 Migrate the full local dataset into prod, then refresh both frontend snapshot secrets from the prod environment and sync only prod/repo GitHub secrets.
    "content:migrate:local-to-prod:refresh-snapshots": "bash ./scripts/migrate-and-refresh-snapshots.sh --source local --target prod",
    // 🪄 Export the full local dataset into the configured content root
    "content:pull:local:content-dir": "bash ./scripts/content-workflow.sh pull-local",
    // 🪄 Export the full dev dataset into the configured content root
    "content:pull:dev:content-dir": "bash ./scripts/content-workflow.sh pull-dev",
    // 🪄 Pull both authored production project descriptions and CV experience seedings in one run
    "content:pull:prod:all": "npm run content:pull:prod:content-dir",
    // 🧪 Dry run: preview all authored production content pulls
    "content:pull:prod:all:dry": "npm run content:pull:prod:content-dir:dry",
    // 🪄 Import a target content root into local: seed media then import project descriptions and CV content.
    // Content-root resolution and validation are centralized in scripts/content-workflow.sh.
    "content:import:local:content-dir": "bash ./scripts/content-workflow.sh import-local",
    // 🪄 Import only local project descriptions and project media from the configured content root.
    "content:import:local:projects:content-dir": "bash ./scripts/content-workflow.sh import-projects-local",
    // 🪄 Import only local CV experiences and CV logo media from the configured content root.
    "content:import:local:cv:content-dir": "bash ./scripts/content-workflow.sh import-cv-local",
    // 🪄 Import target content into dev. Requires ALLOW_DEV_WRITE=true.
    "content:import:dev:content-dir": "bash ./scripts/content-workflow.sh import-dev",
    // 🪄 Import target content into prod. Requires ALLOW_PROD_WRITE=true and extra confirmation.
    "content:import:prod:content-dir": "bash ./scripts/content-workflow.sh import-prod",
    // 🪄 One-shot database sync across environments via the canonical Mongo migration tool.
    // Usage: npm run data:sync -- local dev --dry-run --collections cvexperienceitems
    "data:sync": "bash ./scripts/migrate-database.sh",
    // 🪄 Pull prod media + authored content into the configured content root.
    "content:pull:prod:content-dir": "bash ./scripts/content-workflow.sh pull-prod",
    // 🧪 Dry-run variant of content:pull:prod:content-dir.
    "content:pull:prod:content-dir:dry": "bash ./scripts/content-workflow.sh pull-prod-dry",
    // 🪄 Generate the portfolio images from PSDs from *outside* of the repo. Run before media:seed.
    "media:export": "bash scripts/export-media.sh",
    // 🪄 Pull media assets from S3 using the script defaults
    "media:pull": "tsx scripts/pull-media-from-s3.ts",
    // 🪄 Pull production CV experience logos from S3 into the local workspace
    "media:pull:prod:cv-experience-logos": "tsx scripts/pull-media-from-s3.ts --env prod --collection cv-experience-logos",
    // 🧪 Dry run: preview production CV experience logo downloads without writing files
    "media:pull:prod:cv-experience-logos:dry": "tsx scripts/pull-media-from-s3.ts --env prod --collection cv-experience-logos --dry-run",
    // 🪄 Pull production project brand logos from S3 into the local workspace
    "media:pull:prod:project-brand-logos": "tsx scripts/pull-media-from-s3.ts --env prod --collection project-brand-logos",
    // 🧪 Dry run: preview production project brand logo downloads without writing files
    "media:pull:prod:project-brand-logos:dry": "tsx scripts/pull-media-from-s3.ts --env prod --collection project-brand-logos --dry-run",
    // 🪄 Import images from ../cms-media-seedings into backend/media/* for local dev
    "media:seed": "tsx scripts/import-media-from-seedings.ts",
    // Upload media using the script defaults or explicit CLI flags.
    "media:upload": "tsx scripts/upload-media-to-s3.ts",
    // 🪄 Upload media only to the development S3 bucket
    "media:upload:dev": "tsx scripts/upload-media-to-s3.ts --env dev",
    // 🧪 Dry run: show planned dev uploads (no S3 writes)
    "media:upload:dev:dry": "tsx scripts/upload-media-to-s3.ts --env dev --dry-run",
    // 🪄 Upload media only to the production S3 bucket
    "media:upload:prod": "tsx scripts/upload-media-to-s3.ts --env prod",
    // 🧪 Dry run: show planned prod uploads (no S3 writes)
    "media:upload:prod:dry": "tsx scripts/upload-media-to-s3.ts --env prod --dry-run",
    // 🪄 Upload media to BOTH dev and prod buckets in one run
    "media:upload:both": "tsx scripts/upload-media-to-s3.ts --env both",
    // 🧪 Dry run: show planned dev+prod uploads (no S3 writes)
    "media:upload:both:dry": "tsx scripts/upload-media-to-s3.ts --env both --dry-run",
    // 🪄 Verify uploaded media files on S3 to ensure integrity
    "media:verify": "tsx scripts/verify-media-s3.ts",
    // 🔗 PREVIEW: Update media URLs in development database to point to S3 (dry run)
    "migrate:media-urls:dev:dry": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env dev --dry-run",
    // 🔗 Update media URLs in development database to point to S3
    "migrate:media-urls:dev": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env dev",
    // 🔗 PREVIEW: Update media URLs in production database to point to S3 (dry run)
    "migrate:media-urls:prod:dry": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env prod --dry-run",
    // 🔗 Update media URLs in production database to point to S3
    "migrate:media-urls:prod": "cd backend && tsx scripts/ops/ops-db-migrate-media-urls-to-s3.ts --env prod",
    // 📦 PREVIEW: Complete media migration to development (upload + URL sync, dry run)
    "migrate:all:dev:dry": "npm run media:upload:dev:dry && npm run migrate:media-urls:dev:dry",
    // 📦 Complete media migration to development environment (upload + URL sync)
    "migrate:all:dev": "npm run media:upload:dev && npm run migrate:media-urls:dev",
    // 📦 PREVIEW: Complete media migration to production (upload + URL sync, dry run)
    "migrate:all:prod:dry": "npm run media:upload:prod:dry && npm run migrate:media-urls:prod:dry",
    // 📦 Complete media migration to production environment (upload + URL sync)
    "migrate:all:prod": "npm run media:upload:prod && npm run migrate:media-urls:prod",
    // Upload project files to S3 using the script defaults or explicit CLI flags.
    "projects:upload": "tsx scripts/upload-projects-to-s3.ts",
    // 📁 Upload project files to public S3 bucket
    "projects:upload:public": "tsx scripts/upload-projects-to-s3.ts --env public",
    // 📁 Upload project files to NDA S3 bucket (requires authentication to access)
    "projects:upload:nda": "tsx scripts/upload-projects-to-s3.ts --env nda",
    // 📁 Upload project files to both public and NDA S3 buckets
    "projects:upload:both": "tsx scripts/upload-projects-to-s3.ts --env both",
    // 📁 Verify uploaded project files on S3 to ensure integrity
    "projects:verify": "tsx scripts/verify-projects-s3.ts",
    // ☢️🔥 DANGER: Overwrites dev DB with local data.
    // Pass through flags after `--`, for example: `npm run db:migrate:local-to-dev -- --collections users`.
    "db:migrate:local-to-dev": "bash scripts/migrate-database.sh local dev",
    // ☢️⚰️ DANGER: Overwrites dev DB with production data.
    // You can scope the migration to selected collections with the same `-- --collections ...` pass-through.
    "db:migrate:prod-to-dev": "bash scripts/migrate-database.sh prod dev",
    // ☢️⚠️ DANGER: Overwrites local DB with production data.
    // Use the same extra-args pass-through if you only need selected collections.
    "db:migrate:prod-to-local": "bash scripts/migrate-database.sh prod local",
    // ☢️ Convenience: run prod→dev then prod→local
    "db:migrate:prod-to-all": "npm run db:migrate:prod-to-dev && npm run db:migrate:prod-to-local",
    // 🔐 Restore Payload auth collections (users + payload-preferences) from the most recent prod backup
    "db:restore:auth:prod": "bash scripts/restore-collections-from-backup.sh prod",
    // 🧪 Dry run only: show which backup would be used and the mongorestore command
    "db:restore:auth:prod:dry": "bash scripts/restore-collections-from-backup.sh prod --dry-run",
    // 🔐 Restore Payload auth collections (users + payload-preferences) from the most recent dev backup
    "db:restore:auth:dev": "bash scripts/restore-collections-from-backup.sh dev",
    // 🧪 Dry run only: show which backup would be used and the mongorestore command
    "db:restore:auth:dev:dry": "bash scripts/restore-collections-from-backup.sh dev --dry-run",
    // 🎭 DEPLOYMENT: Deployment Runner (Single-Instance / Current)
    // =============================================================================
    // NAMING CONVENTION:
    //   deploy:xxx  = calls deploy/scripts/deployment-runner.sh with flags (same script)
    //   deploy-xxx  = calls separate script (different script)
    // =============================================================================
    // WORKFLOW:
    //   1. Run `deploy` to deploy the current single-instance stack
    //   2. Validate health via the canonical hosts and/or localhost checks
    // =============================================================================
    // Deploy the current single-instance stack.
    // Runs: terraform (unless skipped), image build/push (unless disabled), GitHub Actions deploy, nginx sync
    "deploy": "bash deploy/scripts/deployment-runner.sh --profiles both --refresh-env",
    // Rebuild+push both prod/dev images before dispatching redeploy workflows
    // Useful when backend/frontend code changed and new images must be published
    "deploy:rebuild": "bash deploy/scripts/deployment-runner.sh --profiles both --rebuild-images --refresh-env",
    // Deploy using existing images (skip Docker build/push to registries)
    // Useful for config-only changes or when images are already built and pushed
    // Still provisions infrastructure and deploys containers from DockerHub/ECR
    "deploy:no-build": "bash deploy/scripts/deployment-runner.sh --profiles both --no-build --refresh-env",
    // Skip-infra deployment (no Terraform/host maintenance)
    // Rebuilds/pushes images (unless --no-build) then asks GH Actions to restart containers
    // Useful for application updates when infrastructure is stable
    "deploy:skip-infra": "bash deploy/scripts/deployment-runner.sh --profiles both --skip-infra --refresh-env",
    // Build and push production images to ECR using the current deployment configuration.
    "ecr:build:push": "bash deploy/scripts/publish-ecr-images.sh",
    // 🏗️ Infrastructure: Sync .env file with Terraform state (interactive)
    "infra:sync-env": "cd infra && bash sync-env-from-terraform.sh",
    // 🏗️ Infrastructure: Sync .env file with Terraform state (skip confirmation)
    "infra:sync-env:force": "cd infra && bash sync-env-from-terraform.sh --force",
    // Housekeeping: prune old images across Docker Hub and ECR (retain 6) (Terraform expires them past counts anyway)
    "images:cleanup": "bash ./scripts/image-cleanup.sh --retain 3 --include-untagged --login --profile bb-portfolio-user --region us-west-2",
    // Dry-run cleanup: show what would be removed without deleting
    "images:cleanup:dry-run": "bash ./scripts/image-cleanup.sh --retain 3 --include-untagged --login --profile bb-portfolio-user --region us-west-2 --dry-run",
    // ECR-only cleanup: prune old images (retain 6)
    "images:cleanup:ecr": "bash ./scripts/image-cleanup-ecr.sh --retain 3 --include-untagged",
    // ECR-only cleanup (dry run)
    "images:cleanup:ecr:dry-run": "bash ./scripts/image-cleanup-ecr.sh --retain 3 --include-untagged --dry-run",
    // Same as images:cleanup, but performs AWS/ECR login explicitly first
    "images:cleanup:login": "bash ./scripts/image-cleanup.sh --retain 3 --include-untagged --login --profile bb-portfolio-user --region us-west-2",
    // Verify image tags and counts in Docker Hub and ECR
    "images:verify": "bash ./scripts/images-verify.sh",
    // Verify counts after logging into AWS/ECR (useful on fresh shells)
    "images:verify:login": "bash ./scripts/images-verify.sh --login --profile bb-portfolio-user --region us-west-2",
    // ⚡ Fast repo search using ripgrep (pass pattern after `--`)
    "search:repo": "rg --line-number --hidden --follow --glob '!.git' --glob '!node_modules' --glob '!frontend/.next' --glob '!backend/.next'",
    // 📄 Quickly list files matching glob filters (shares ignore rules above)
    "search:files": "rg --files --hidden --follow --glob '!.git' --glob '!node_modules' --glob '!frontend/.next' --glob '!backend/.next'",
    // 🚀 Promote the validated dev branch through the release flow and return to dev.
    "release:promote": "bash ./scripts/sync-branches.sh",
    // 🚀 Synchronize dev and main without the canonical version bump commit, triggering both workflows as needed.
    "release:sync-only": "bash ./scripts/sync-branches.sh --no-version-bump",
  },
  // Development tooling for the monorepo root (formatting, linting, TS, runners)
  "devDependencies": {
    // Next.js-specific ESLint rules for best practices
    "@next/eslint-plugin-next": "^16.2.6",
    // TypeScript type definitions for glob
    "@types/glob": "^9.0.0",
    // ESLint plugin for TypeScript-specific linting rules
    "@typescript-eslint/eslint-plugin": "8.59.2",
    // TypeScript parser for ESLint
    "@typescript-eslint/parser": "8.59.2",
    // Maps baseline browser support targets for tooling that needs them
    "baseline-browser-mapping": "^2.10.29",
    // Run multiple commands concurrently in scripts
    "concurrently": "^9.2.1",
    // Main linter for JS/TS code
    "eslint": "^9.39.4",
    // ESLint plugin for import/export syntax validation
    "eslint-plugin-import": "^2.32.0",
    // ESLint plugin for React hooks rules
    "eslint-plugin-react-hooks": "^7.1.1",
    // ESLint plugin for React Fast Refresh support
    "eslint-plugin-react-refresh": "^0.5.2",
    // File pattern matching utility
    "glob": "^13.0.6",
    // List of global variables for linting
    "globals": "^17.6.0",
    // Utility for .gitignore-style file filtering
    "ignore": "^7.0.5",
    // Runtime for dynamic JS/TS imports
    "jiti": "^2.7.0",
    // JSON5 parser for annotated config files
    "json5": "^2.2.3",
    // CLI that syncs documented package.json5 companions from canonical package.json files
    "json5-manifest-sync": "^0.2.1",
    // Code formatter for consistent style
    "prettier": "^3.8.3",
    // TypeScript execution environment for scripts
    "ts-node": "^10.9.2",
    // TypeScript/ESM runner for scripts
    "tsx": "^4.21.0",
    // TypeScript language support
    "typescript": "^6.0.3",
  },
  // Root-level runtime deps used by maintenance scripts (prefer package-level deps when possible)
  "dependencies": {
    // JWT utilities used by local maintenance scripts
    "jsonwebtoken": "^9.0.3",
  },
}