{
  "name": "bb-portfolio-backend",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "precommit": "prettier --write . && tsc -b",
    "prebuild": "tsx ./scripts/check-required-env.ts",
    "predev": "tsx ./scripts/check-required-env.ts && npm run generate:importmap",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" npm run generate:importmap && next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation npm run generate:importmap && next dev -p ${PORT:-3000}",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "seed:cv-experience": "cross-env NODE_OPTIONS=--no-deprecation tsx ./scripts/seed-cv-experience.ts",
    "seed:cv-experience:local": "npm run seed:cv-experience -- --env local",
    "seed:cv-experience:dev": "npm run seed:cv-experience -- --env dev",
    "smoke:admin-login": "node scripts/smoke-admin-login.mjs",
    "lint": "cd .. && eslint backend",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "prestart": "tsx ./scripts/check-required-env.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1012.0",
    "@aws-sdk/types": "^3.973.6",
    "@payloadcms/db-mongodb": "3.79.1",
    "@payloadcms/email-nodemailer": "3.79.1",
    "@payloadcms/next": "3.79.1",
    "@payloadcms/payload-cloud": "3.79.1",
    "@payloadcms/richtext-lexical": "3.79.1",
    "@payloadcms/storage-s3": "3.79.1",
    "@payloadcms/ui": "3.79.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "json5": "^2.2.3",
    "next": "16.2.0",
    "payload": "3.79.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5",
    "slugify": "^1.6.8"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.0",
    "jsdom": "29.0.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "overrides": {
    "nodemailer": "7.0.12"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "onlyBuiltDependencies": [
    "sharp",
    "esbuild",
    "unrs-resolver"
  ]
}
