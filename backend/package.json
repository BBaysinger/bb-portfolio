{
  "name": "bb-portfolio-backend",
  "version": "0.0.87",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "precommit": "prettier --write . && tsc -b",
    "prebuild": "tsx ./scripts/check-required-env.ts",
    "predev": "tsx ./scripts/check-required-env.ts && npm run generate:importmap",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" npm run generate:importmap && next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation npm run generate:importmap && sh ./scripts/run-next-dev.sh",
    "dev:clean": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation sh ./scripts/run-next-dev.sh",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation sh ./scripts/generate-importmap-stable.sh",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "export:cv-content": "cross-env NODE_OPTIONS=--no-deprecation tsx ./scripts/export-cv-experience-content.ts",
    "export:project-descriptions": "cross-env NODE_OPTIONS=--no-deprecation tsx ./scripts/export-project-descriptions-content.ts",
    "import:cv-content": "cross-env NODE_OPTIONS=--no-deprecation tsx ./scripts/import-cv-experience-content.ts",
    "import:cv-content:local": "npm run import:cv-content -- --env local",
    "import:cv-content:dev": "npm run import:cv-content -- --env dev",
    "import:project-descriptions": "cross-env NODE_OPTIONS=--no-deprecation tsx ./scripts/import-project-descriptions-content.ts",
    "import:project-descriptions:local": "npm run import:project-descriptions -- --env local",
    "import:project-descriptions:dev": "npm run import:project-descriptions -- --env dev",
    "seed:cv-experience": "cross-env NODE_OPTIONS=--no-deprecation tsx ./scripts/seed-cv-experience.ts",
    "seed:cv-experience:local": "npm run seed:cv-experience -- --env local",
    "seed:cv-experience:dev": "npm run seed:cv-experience -- --env dev",
    "update:contact-info": "cross-env NODE_OPTIONS=--no-deprecation tsx ./scripts/update-contact-info.ts",
    "update:contact-info:local": "npm run update:contact-info -- --env local",
    "update:contact-info:dev": "npm run update:contact-info -- --env dev",
    "smoke:admin-login": "tsx scripts/smoke-admin-login.ts",
    "lint": "cd .. && eslint backend",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "prestart": "tsx ./scripts/check-required-env.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "npm run test:integration && npm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" npx playwright test",
    "test:integration": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1087.0",
    "@aws-sdk/types": "^3.974.1",
    "@payloadcms/db-mongodb": "3.86.0",
    "@payloadcms/email-nodemailer": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/payload-cloud": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-s3": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "bson": "^7.3.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "js-yaml": "^4.2.0",
    "json5": "^2.2.3",
    "mongodb": "~7.5.0",
    "next": "16.2.10",
    "payload": "3.86.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "baseline-browser-mapping": "^2.10.43",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "playwright-core": "1.61.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "overrides": {
    "nodemailer": "7.0.12"
  },
  "engines": {
    "node": "^20.13.0 || ^22.13.0 || >=24 <26",
    "npm": ">=10.5 <12",
    "pnpm": "^9 || ^10"
  },
  "onlyBuiltDependencies": [
    "sharp",
    "esbuild",
    "unrs-resolver"
  ],
  "packageManager": "npm@10.5.2"
}
